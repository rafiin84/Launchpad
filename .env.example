# Launchpad environment variables
# Copy this file to `.env` and fill in the values, then restart `npm run dev`.

# ── Optional: file uploads for founders ─────────────────────────────────────
# Zoho blocks portal (founder) users from the CRM Attachments API, so the
# founder "Upload" button uploads to Cloudinary instead (pure client-side,
# no secret). Leave blank to hide the Upload button — the share-link option
# always works regardless.
#
# Setup (free, ~2 min):
#   1. Sign up at https://cloudinary.com
#   2. Dashboard → copy your "Cloud name"
#   3. Settings → Upload → Upload presets → Add preset → Signing mode: Unsigned
#   4. Paste the cloud name + preset name below and restart the dev server.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
